# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/greenmind?appName=YourApp

# Firebase Configuration (Client - Public)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin SDK (Server - Private)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_base64_encoded_private_key_here\n-----END PRIVATE KEY-----\n"

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here
